.DS_Store
node_modules/
dist/
.venv/
__pycache__/
.pytest_cache/
*.pyc
.lake/

# Environment files — all variants, but keep tracked templates
.env
.env.*
!.env.example
!.env.*.example

# Common secret material (defense in depth)
*.key
*.pem
*.token
.gemini_key
.github_token
*credentials*.json
*secret*.json

# App-local generated state & private config (location-independent,
# so each workspace's files are ignored wherever it lives in the tree)
.overleaf-lean-stub/
lea.local.toml
data/

# LaTeX build artifacts (docs/ testing fixtures are compiled locally;
# only the .tex sources belong in git)
*.aux
*.fdb_latexmk
*.fls
*.out
*.synctex.gz
docs/*.log
docs/*.pdf
