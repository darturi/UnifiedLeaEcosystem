{
  "name": "lea-ecosystem",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "update-lean-deps": "node scripts/setup.mjs --refresh-lean-deps",
    "start:adapter": "npm run start:api -w apps/lea-standalone",
    "dev:overleaf": "npm start -w apps/overleaf-extension",
    "dev:ui": "npm run dev -w apps/lea-standalone",
    "doctor": "npm run doctor -w apps/overleaf-extension && npm run doctor -w apps/lea-standalone",
    "reset:local": "node scripts/reset-local-state.mjs",
    "test": "npm test -w apps/overleaf-extension && npm run test:frontend -w apps/lea-standalone"
  }
}
