LEA_ROOT=vendor/lea-prover
LEA_API_BASE_URL=http://127.0.0.1:8000
LEA_API_KEY=
LEA_UI_API_BASE_URL=http://127.0.0.1:8001
LEA_UI_BASE_URL=http://localhost:5173
OVERLEAF_COMPANION_URL=http://127.0.0.1:31245

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
OPENAI_BASE_URL=

LEA_PROVIDER=openai
LEA_MODEL=o4-mini
LEA_MAX_TURNS=20
LEA_MAX_SPEND_USD=
LEA_JOB_TIMEOUT_SECONDS=900
LEA_THEOREM_TRANSLATION_MAX_RETRIES=3
LEA_PERMISSION_TIER=theorem_translation
LEA_NARRATE_TOOL_STEPS=true

# Shared process state
# When true, the Overleaf extension records each run's full process timeline
# (messages, code steps, approvals, usage) into the shared database so it is
# visible in the Lea UI exactly like a UI-originated run.
LEA_SHARED_STATE=false
# Where the shared SQLite database and raw event logs live. Defaults to the UI
# app's existing data directory (apps/lea-ui/data) so both apps share one store
# with no migration. Relative paths are anchored at the monorepo root.
# LEA_SHARED_DATA_DIR=apps/lea-ui/data
# LEA_DB_PATH=
# LEA_EVENT_LOG_DIR=
# Python interpreter used to run the shared-state recorder (the Lea UI server's
# app.recorder module). Defaults to apps/lea-ui/server/.venv/bin/python.
# LEA_RECORDER_PYTHON=
# LEA_UI_SERVER_DIR=apps/lea-ui/server
