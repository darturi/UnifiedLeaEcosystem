LEA_ROOT=apps/lea-standalone/prover
# The standalone adapter is the single backend for both apps; it runs on :8001.
LEA_API_BASE_URL=http://127.0.0.1:8001
# Which Lea wire the Overleaf companion speaks: "api" = the standalone adapter
# (default); "v1" = the legacy vendored Lea API (retired — rollback only).
LEA_API_FLAVOR=api
LEA_API_KEY=
LEA_UI_BASE_URL=http://localhost:5173
OVERLEAF_COMPANION_URL=http://127.0.0.1:31245

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
OPENAI_BASE_URL=

LEA_PROVIDER=openai
LEA_MODEL=o4-mini
LEA_MAX_TURNS=20
LEA_MAX_SPEND_USD=
LEA_JOB_TIMEOUT_SECONDS=900
LEA_NARRATE_TOOL_STEPS=true

# --- Deferred / legacy rollback settings ------------------------------------
# Theorem-translation approval (stub-then-formalize) and the shared-state
# recorder were features of the legacy vendored /v1 backend. They are not active
# on the standalone /api backend yet:
#   * Approval tier: being added natively to the standalone prover/adapter.
#   * Project recording / formalized status: deferred adapter-side.
#   * Shared-state recorder: under /api, runs are recorded by the adapter itself,
#     so the separate recorder below is not used.
# These remain only for `LEA_API_FLAVOR=v1` rollback.
# LEA_THEOREM_TRANSLATION_MAX_RETRIES=3
# LEA_PERMISSION_TIER=theorem_translation
# LEA_SHARED_STATE=false
# LEA_RECORDER_PYTHON=
